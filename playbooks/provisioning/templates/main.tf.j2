# ============================================================
# AIOps Lab - AWS Infrastructure (Generated by Ansible)
# ============================================================
# Tags alimentam o inventário dinâmico do AAP:
#   Tag:Name  → aws_name_tag + index
#   Tag:Group → server_group
#   Tag:Role  → server_role
# ============================================================

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

# --- Data: Latest RHEL 9 AMI ---
data "aws_ami" "rhel9" {
  most_recent = true
  owners      = ["309956199498"]  # Red Hat

  filter {
    name   = "name"
    values = ["RHEL-9.*_HVM-*-x86_64-*-Hourly*"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

# --- SSH Key Pair ---
resource "aws_key_pair" "lab_key" {
  key_name   = "${var.aws_name_tag}-key"
  public_key = var.aws_instance_public_key
}

# --- Security Group ---
resource "aws_security_group" "lab_sg" {
  name        = "${var.aws_name_tag}-sg"
  description = "AIOps Lab - Allow SSH, HTTP, HTTPS, monitoring"

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "SSH"
  }

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "HTTP"
  }

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "HTTPS"
  }

  ingress {
    from_port   = 9100
    to_port     = 9100
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "Node Exporter"
  }

  ingress {
    from_port   = 9090
    to_port     = 9090
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "Prometheus"
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name      = "${var.aws_name_tag}-sg"
    ManagedBy = "ansible-terraform"
  }
}

# --- EC2 Instances ---
resource "aws_instance" "server" {
  count                  = var.aws_instance_count
  ami                    = data.aws_ami.rhel9.id
  instance_type          = var.aws_instance_size
  key_name               = aws_key_pair.lab_key.key_name
  vpc_security_group_ids = [aws_security_group.lab_sg.id]

  root_block_device {
    volume_size = {{ disk_size | default(30) }}
    volume_type = "gp3"
  }

  tags = {
    Name      = "${var.aws_name_tag}-${count.index + 1}"
    Role      = var.server_role
    Group     = var.server_group
    OS        = "RHEL9"
    ManagedBy = "ansible-terraform"
  }
}
