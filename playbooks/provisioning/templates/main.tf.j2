# ============================================================
# AIOps Lab - AWS Infrastructure (Generated by Ansible)
# ============================================================
# Tags são a base do inventário dinâmico:
#   Tag:Name  → Nome do servidor
#   Tag:Group → Grupo/aplicação (ex: webservers, app_tier)
#   Tag:Role  → Função (ex: webserver, database)
# ============================================================

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region
}

# --- Data: Latest RHEL 9 AMI ---
data "aws_ami" "rhel9" {
  most_recent = true
  owners      = ["309956199498"]  # Red Hat

  filter {
    name   = "name"
    values = ["RHEL-9.*_HVM-*-x86_64-*-Hourly*"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

# --- SSH Key Pair ---
resource "aws_key_pair" "lab_key" {
  key_name   = "${var.project_name}-key"
  public_key = var.ssh_public_key
}

# --- Security Group ---
resource "aws_security_group" "lab_sg" {
  name        = "${var.project_name}-sg"
  description = "AIOps Lab - Allow SSH, HTTP, HTTPS, monitoring"

  # SSH
  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "SSH"
  }

  # HTTP
  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "HTTP"
  }

  # HTTPS
  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "HTTPS"
  }

  # Node Exporter
  ingress {
    from_port   = 9100
    to_port     = 9100
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "Node Exporter"
  }

  # Prometheus
  ingress {
    from_port   = 9090
    to_port     = 9090
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "Prometheus"
  }

  # Egress
  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name        = "${var.project_name}-sg"
    Project     = var.project_name
    Environment = var.environment
    ManagedBy   = "ansible-terraform"
  }
}

# --- EC2 Instances ---
# Cada servidor tem seu próprio instance_type (modelo)
# Tags (Name, Group, Role) alimentam o inventário dinâmico do AAP
{% for server in servers %}
resource "aws_instance" "{{ server.name | replace('-', '_') | replace('.', '_') }}" {
  ami                    = data.aws_ami.rhel9.id
  instance_type          = "{{ server.instance_type | default(instance_type) }}"
  key_name               = aws_key_pair.lab_key.key_name
  vpc_security_group_ids = [aws_security_group.lab_sg.id]

  root_block_device {
    volume_size = {{ server.disk_size | default(30) }}
    volume_type = "gp3"
  }

  tags = {
    Name        = "{{ server.name }}"
    Project     = var.project_name
    Environment = var.environment
    Role        = "{{ server.role | default('managed') }}"
    Group       = "{{ server.group | default('managed_servers') }}"
    OS          = "RHEL9"
    ManagedBy   = "ansible-terraform"
{% for key, value in (server.extra_tags | default({})).items() %}
    {{ key }}   = "{{ value }}"
{% endfor %}
  }
}
{% endfor %}
