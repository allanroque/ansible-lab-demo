output "server_public_ips" {
  description = "Public IPs of all instances"
  value       = aws_instance.server[*].public_ip
}

output "server_private_ips" {
  description = "Private IPs of all instances"
  value       = aws_instance.server[*].private_ip
}

output "server_instance_ids" {
  description = "Instance IDs of all instances"
  value       = aws_instance.server[*].id
}

output "server_info" {
  description = "Complete server info list"
  value = [
    for i, instance in aws_instance.server : {
      name          = "${var.aws_name_tag}-${i + 1}"
      public_ip     = instance.public_ip
      private_ip    = instance.private_ip
      instance_id   = instance.id
      instance_type = var.aws_instance_size
      role          = var.server_role
      group         = var.server_group
    }
  ]
}
